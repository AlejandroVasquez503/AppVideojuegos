@{
    Layout = null;
    var usuario = Context.Session.GetString("usuario");
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Dashboard</title>

    <script src="https://code.highcharts.com/highcharts.js"></script>
    <script src="https://code.highcharts.com/modules/exporting.js"></script>
    <script src="https://code.highcharts.com/modules/export-data.js"></script>
    <script src="https://code.highcharts.com/modules/accessibility.js"></script>
    <script src="https://code.highcharts.com/themes/adaptive.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.js" integrity="sha256-eKhayi8LEQwp4NKxN+CfCh+3qOVUtJn3QNZ0TciWLP4=" crossorigin="anonymous"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>

        body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol", sans-serif;
        background: var(--highcharts-background-color);
        color: var(--highcharts-neutral-color-100);
        }

        .highcharts-figure,
        .highcharts-data-table table {
        min-width: 310px;
        max-width: 800px;
        margin: 1em auto;
        }

        #container {
        height: 400px;
        }

        .highcharts-data-table table {
        font-family: Verdana, sans-serif;
        border-collapse: collapse;
        border: 1px solid var(--highcharts-neutral-color-10, #e6e6e6);
        margin: 10px auto;
        text-align: center;
        width: 100%;
        max-width: 500px;
        }

        .highcharts-data-table caption {
        padding: 1em 0;
        font-size: 1.2em;
        color: var(--highcharts-neutral-color-60, #666);
        }

        .highcharts-data-table th {
        font-weight: 600;
        padding: 0.5em;
        }

        .highcharts-data-table td,
        .highcharts-data-table th,
        .highcharts-data-table caption {
        padding: 0.5em;
        }

        .highcharts-data-table thead tr,
        .highcharts-data-table tbody tr:nth-child(even) {
        background: var(--highcharts-neutral-color-3, #f7f7f7);
        }

        .highcharts-description {
        margin: 0.3rem 10px;
        }


        /* //espacio */
            body {
                background-color: #f5f7fb;
            }

            .navbar-custom {
                background: linear-gradient(90deg, #1e3c72, #2a5298);
            }

            .navbar-brand {
                font-weight: bold;
                color: white !important;
            }

            .user-info {
                color: white;
                font-weight: 500;
            }

            .btn-logout {
                border-radius: 10px;
            }

            .dashboard-container {
                padding: 30px;
            }

            .card-placeholder {
                height: 250px;
                border-radius: 15px;
                border: 2px dashed #ccc;
                display: flex;
                align-items: center;
                justify-content: center;
                color: #999;
                font-weight: 500;
                background: white;
            }

            .welcome-box {
                background: white;
                padding: 20px;
                border-radius: 15px;
                margin-bottom: 20px;
                box-shadow: 0 5px 15px rgba(0,0,0,0.05);
            }

            .welcome-box h4 {
                color: #000 !important;
            }
    </style>
</head>
<body>

   
    <nav class="navbar navbar-expand-lg navbar-custom px-4">
        <a class="navbar-brand" href="#">Administración de sistema</a>

        <div class="ms-auto d-flex align-items-center gap-3">
            <span class="user-info">
                👤 @usuario
            </span>

            <a asp-controller="Account" asp-action="Logout" class="btn btn-light btn-sm btn-logout">
                Cerrar Sesión
            </a>
        </div>
    </nav>
    <div class="dashboard-container">

      
        <div class="welcome-box">
            <h4>Bienvenido, @usuario 👋</h4>
            <p class="text-muted mb-0">
                Este es tu panel principal. Aquí podrás visualizar estadísticas y gestionar el sistema.
            </p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-3">
                Ir a Home
            </a>
        </div>

    <div class="row g-4">
        <!-- Gráfica 1: Cantidad de Juegos por Categoría -->
        <div class="col-md-6">
            <div class="mb-3">
                <label class="form-label" style="color: #333; font-weight: bold;">Filtrar por Categoría (Juegos):</label>
                <select id="filtroCategoria1" class="form-select">
                    <option value="">Todas las categorias</option>
                    @foreach(var cat in (List<appWeb2.Models.Categoria>)ViewBag.Categorias)
                    {
                        <option value="@cat.idcategoria">@cat.categoria</option>
                    }
                </select>
            </div>
            <div id="container1"></div>
        </div>

        <!-- Gráfica 2: Juegos en Promoción vs Sin Promoción -->
        <div class="col-md-6">
            <div class="mb-3">
                <label class="form-label" style="color: #333; font-weight: bold;">Filtrar por Categoría (Promociones):</label>
                <select id="filtroCategoria2" class="form-select">
                    <option value="">Todas las categorias</option>
                    @foreach(var cat in (List<appWeb2.Models.Categoria>)ViewBag.Categorias)
                    {
                        <option value="@cat.idcategoria">@cat.categoria</option>
                    }
                </select>
            </div>
            <div id="container2"></div>
        </div>
    </div>

    <div class="row g-4 mt-2">
        <!-- Gráfica 3: Ingresos Estimados por Categoría -->
        <div class="col-md-6">
            <div class="mb-3">
                <label class="form-label" style="color: #333; font-weight: bold;">Filtrar por Categoría (Ingresos):</label>
                <select id="filtroCategoria3" class="form-select">
                    <option value="">Todas las categorias</option>
                    @foreach(var cat in (List<appWeb2.Models.Categoria>)ViewBag.Categorias)
                    {
                        <option value="@cat.idcategoria">@cat.categoria</option>
                    }
                </select>
            </div>
            <div id="container3"></div>
        </div>

        <!-- Gráfica 4: Precio Promedio por Categoría -->
        <div class="col-md-6">
            <div class="mb-3">
                <label class="form-label" style="color: #333; font-weight: bold;">Filtrar por Categoría (Precios):</label>
                <select id="filtroCategoria4" class="form-select">
                    <option value="">Todas las categorias</option>
                    @foreach(var cat in (List<appWeb2.Models.Categoria>)ViewBag.Categorias)
                    {
                        <option value="@cat.idcategoria">@cat.categoria</option>
                    }
                </select>
            </div>
            <div id="container4"></div>
        </div>
    </div>

    </div>

</body>

<script>
    // Gráfica 1: Cantidad de Juegos por Categoría
    function cargarGrafica1(idcategoria = ""){
        $.get('/Account/ObtenerDatos', {idcategoria: idcategoria}, function(data){
            var categorias = data.map(x => x.categoria);
            var totales = data.map(x => x.total);

            Highcharts.chart('container1', {
                chart: {
                    type: 'column'
                },
                title: {
                    text: 'Cantidad de Videojuegos por Categoría'
                },
                xAxis: {
                    categories: categorias,
                    title: {
                        text: 'Categorías'
                    }
                },
                yAxis: {
                    min: 0,
                    title: {
                        text: 'Cantidad de juegos'
                    }
                },
                series: [{
                    name: 'Juegos',
                    data: totales,
                    color: '#2a5298'
                }]
            });
        });
    }

    // Gráfica 2: Juegos en Promoción vs Sin Promoción
    function cargarGrafica2(idcategoria = ""){
        $.get('/Account/ObtenerPromociones', {idcategoria: idcategoria}, function(data){
            var estados = data.map(x => x.estado);
            var totales = data.map(x => x.total);

            Highcharts.chart('container2', {
                chart: {
                    type: 'pie'
                },
                title: {
                    text: 'Juegos en Promoción vs Sin Promoción'
                },
                tooltip: {
                    pointFormat: '<b>{point.y}</b> ({point.percentage:.1f}%)'
                },
                plotOptions: {
                    pie: {
                        allowPointSelect: true,
                        cursor: 'pointer',
                        dataLabels: {
                            enabled: true,
                            format: '<b>{point.name}</b>: {point.y}'
                        }
                    }
                },
                series: [{
                    name: 'Cantidad',
                    data: estados.map((e, i) => ({
                        name: e,
                        y: totales[i]
                    }))
                }]
            });
        });
    }

    // Gráfica 3: Ingresos Estimados por Categoría
    function cargarGrafica3(idcategoria = ""){
        $.get('/Account/ObtenerIngresosEstimados', {idcategoria: idcategoria}, function(data){
            var categorias = data.map(x => x.categoria);
            var ingresos = data.map(x => x.ingresoEstimado);

            Highcharts.chart('container3', {
                chart: {
                    type: 'column'
                },
                title: {
                    text: 'Ingresos Estimados por Categoría'
                },
                xAxis: {
                    categories: categorias,
                    title: {
                        text: 'Categorías'
                    }
                },
                yAxis: {
                    title: {
                        text: 'Ingresos ($)'
                    }
                },
                tooltip: {
                    pointFormat: '<b>Ingreso: ${point.y:.2f}</b>'
                },
                series: [{
                    name: 'Ingreso Estimado',
                    data: ingresos,
                    color: '#4CAF50'
                }]
            });
        });
    }

    // Gráfica 4: Precio de Juegos por Categoría
    function cargarGrafica4(idcategoria = ""){
        $.get('/Account/ObtenerPreciosJuegos', {idcategoria: idcategoria}, function(data){
            var titulos = data.map(x => x.titulo);
            var precios = data.map(x => x.precio);

            Highcharts.chart('container4', {
                chart: {
                    type: 'scatter'
                },
                title: {
                    text: 'Precio de Videojuegos' + (idcategoria ? ' - ' + data[0].categoria : '')
                },
                xAxis: {
                    categories: titulos,
                    title: {
                        text: 'Juegos'
                    },
                    labels: {
                        rotation: -45,
                        style: {
                            fontSize: '11px'
                        }
                    }
                },
                yAxis: {
                    title: {
                        text: 'Precio ($)'
                    }
                },
                tooltip: {
                    pointFormat: '<b>{point.category}</b><br>Precio: ${point.y:.2f}'
                },
                series: [{
                    name: 'Precio',
                    data: precios.map((precio, index) => ({
                        x: index,
                        y: precio,
                        category: titulos[index]
                    })),
                    color: '#FF6B6B'
                }]
            });
        });
    }

    // Cargar todas las gráficas al iniciar
    cargarGrafica1();
    cargarGrafica2();
    cargarGrafica3();
    cargarGrafica4();

    // Event listeners para los filtros
    $('#filtroCategoria1').change(function(){
        cargarGrafica1($(this).val());
    });

    $('#filtroCategoria2').change(function(){
        cargarGrafica2($(this).val());
    });

    $('#filtroCategoria3').change(function(){
        cargarGrafica3($(this).val());
    });

    $('#filtroCategoria4').change(function(){
        cargarGrafica4($(this).val());
    });
</script>

</html>