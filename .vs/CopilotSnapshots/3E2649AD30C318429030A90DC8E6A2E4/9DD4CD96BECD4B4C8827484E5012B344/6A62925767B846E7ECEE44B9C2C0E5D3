@model appWeb2.Models.VideoJuegos

<h2>Crear Videojuego</h2>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    <div>
        <label>Titulo</label>
        <input asp-for="titulo" class="form-control" />
        <span asp-validation-for="titulo"></span>
    </div>

    <div>
        <label>Precio</label>
        <input asp-for="precio" class="form-control" />
        <div asp-validation-summary="All" class="text-danger"></div>
        <span asp-validation-for="precio"></span>
    </div>

    <div>
        <label>Categoria</label>
        <select asp-for="idcategoria" class="form-control">
            <option value="">-- Selecciona una categoría --</option>
        </select>
        <span asp-validation-for="idcategoria"></span>
    </div>

    <div>
        <label>Descripción</label>
        <textarea asp-for="descripcion" class="form-control"></textarea>
    </div>

    <div>
        <label>Edad Mínima</label>
        <input asp-for="EdadMinima" class="form-control" placeholder="Ej: +12, +18, +3" />
        <span asp-validation-for="EdadMinima"></span>
    </div>

    <div>
        <label>Imagen</label><br> <br>
        <input type="file" name="archivoImagen" class="form-control" /> <br>
    </div>

    <div>
        <label>
            <input type="checkbox" asp-for="EnPromocion" />
            En Promoción
        </label>
    </div>

    <button type="submit" class="btn btn-primary">Guardar</button>
</form>
